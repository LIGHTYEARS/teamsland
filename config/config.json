{
  "meego": {
    "spaces": [{ "spaceId": "xxx", "name": "开放平台前端" }, { "spaceId": "yyy", "name": "开放平台基础" }],
    "eventMode": "webhook",
    "webhook": {
      "host": "127.0.0.1",
      "port": 8090,
      "path": "/meego/webhook",
      "secret": "${MEEGO_WEBHOOK_SECRET}"
    },
    "poll": {
      "intervalSeconds": 60,
      "lookbackMinutes": 5
    },
    "longConnection": {
      "enabled": false,
      "reconnectIntervalSeconds": 10
    },
    "apiBaseUrl": "https://project.feishu.cn/open_api",
    "pluginAccessToken": "${MEEGO_PLUGIN_ACCESS_TOKEN}"
  },
  "lark": {
    "appId": "${LARK_APP_ID}",
    "appSecret": "${LARK_APP_SECRET}",
    "bot": {
      "historyContextCount": 20
    },
    "notification": {
      "teamChannelId": "${LARK_TEAM_CHANNEL_ID}"
    },
    "connector": {
      "enabled": true,
      "eventTypes": ["im.message.receive_v1"],
      "chatProjectMapping": {
        "oc_3e8c9a4f5921e271c530644b6946fc34": "project_xxx"
      }
    }
  },
  "session": {
    "compactionTokenThreshold": 80000,
    "sqliteJitterRangeMs": [20, 150],
    "busyTimeoutMs": 5000
  },
  "sidecar": {
    "maxConcurrentSessions": 20,
    "maxRetryCount": 3,
    "maxDelegateDepth": 2,
    "workerTimeoutSeconds": 300,
    "healthCheckTimeoutMs": 30000,
    "minSwarmSuccessRatio": 0.5
  },
  "memory": {
    "decayHalfLifeDays": 30,
    "extractLoopMaxIterations": 3,
    "exemptTypes": ["decisions", "identity"],
    "perTypeTtl": {
      "profile": 365,
      "preferences": 180,
      "entities": 180,
      "events": 90,
      "cases": 365,
      "patterns": 365,
      "tools": 365,
      "skills": 365,
      "decisions": 365,
      "project_context": 180,
      "soul": 365,
      "identity": 365
    }
  },
  "storage": {
    "sqliteVec": {
      "dbPath": "./data/memory.sqlite",
      "busyTimeoutMs": 5000,
      "vectorDimensions": 1024
    },
    "embedding": {
      "model": "hf:Qwen/Qwen3-Embedding-0.6B-GGUF/Qwen3-Embedding-0.6B-Q8_0.gguf",
      "contextSize": 2048
    },
    "entityMerge": {
      "cosineThreshold": 0.95
    },
    "fts5": {
      "optimizeIntervalHours": 24
    }
  },
  "confirmation": {
    "reminderIntervalMin": 30,
    "maxReminders": 3,
    "pollIntervalMs": 60000
  },
  "dashboard": {
    "port": 3001,
    "auth": {
      "provider": "none",
      "sessionTtlHours": 8,
      "allowedDepartments": []
    }
  },
  "repoMapping": [
    {
      "meegoProjectId": "project_xxx",
      "repos": [{ "path": "/Users/bytedance/workspace/teamsland", "name": "teamsland 主仓库" }]
    }
  ],
  "skillRouting": {
    "frontend_dev": ["figma-reader", "lark-docs", "git-tools", "architect-template"],
    "tech_spec": ["lark-docs", "git-tools", "architect-template"],
    "design": ["figma-reader", "lark-docs", "architect-template"],
    "code_review": ["git-diff", "lark-comment"],
    "bot_query": ["lark-docs", "lark-base"],
    "confirm": ["lark-docs"],
    "status_sync": ["lark-docs", "lark-base"],
    "query": ["lark-docs", "lark-base"],
    "coding": ["lark-reply", "meego-update", "teamsland-report"],
    "research": ["lark-reply", "teamsland-report"],
    "review": ["lark-reply", "meego-update", "teamsland-report"],
    "observer": ["teamsland-report"]
  },
  "llm": {
    "provider": "anthropic",
    "apiKey": "${ANTHROPIC_AUTH_TOKEN}",
    "model": "${ANTHROPIC_MODEL}",
    "baseUrl": "${ANTHROPIC_BASE_URL}",
    "maxTokens": 4096
  },
  "queue": {
    "dbPath": "data/queue.sqlite",
    "busyTimeoutMs": 5000,
    "visibilityTimeoutMs": 360000,
    "maxRetries": 3,
    "deadLetterEnabled": true,
    "pollIntervalMs": 100
  },
  "coordinator": {
    "workspacePath": "~/.teamsland/coordinator",
    "sessionIdleTimeoutMs": 300000,
    "sessionMaxLifetimeMs": 1800000,
    "sessionReuseWindowMs": 300000,
    "maxRecoveryRetries": 3,
    "inferenceTimeoutMs": 300000,
    "enabled": true
  },
  "hooks": {
    "hooksDir": "~/.teamsland/coordinator/hooks",
    "defaultTimeoutMs": 30000,
    "multiMatch": false,
    "pendingDir": "~/.teamsland/coordinator/hooks-pending",
    "requireApproval": true
  }
}
