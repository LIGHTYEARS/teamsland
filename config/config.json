{
  "meego": {
    "spaces": [{ "spaceId": "xxx", "name": "开放平台前端" }, { "spaceId": "yyy", "name": "开放平台基础" }],
    "eventMode": "webhook",
    "webhook": {
      "host": "127.0.0.1",
      "port": 8090,
      "path": "/meego/webhook",
      "secret": "${MEEGO_WEBHOOK_SECRET}"
    },
    "poll": {
      "intervalSeconds": 60,
      "lookbackMinutes": 5
    },
    "longConnection": {
      "enabled": false,
      "reconnectIntervalSeconds": 10
    },
    "apiBaseUrl": "https://project.feishu.cn/open_api",
    "pluginId": "${MEEGO_PLUGIN_ID}",
    "pluginSecret": "${MEEGO_PLUGIN_SECRET}",
    "pluginAccessToken": "${MEEGO_PLUGIN_ACCESS_TOKEN}",
    "userKey": "${MEEGO_USER_KEY}"
  },
  "lark": {
    "appId": "${LARK_APP_ID}",
    "appSecret": "${LARK_APP_SECRET}",
    "bot": {
      "historyContextCount": 20
    },
    "notification": {
      "teamChannelId": "${LARK_TEAM_CHANNEL_ID}"
    },
    "connector": {
      "enabled": true,
      "eventTypes": ["im.message.receive_v1"],
      "chatProjectMapping": {
        "oc_3e8c9a4f5921e271c530644b6946fc34": "project_xxx"
      }
    }
  },
  "session": {
    "compactionTokenThreshold": 80000,
    "sqliteJitterRangeMs": [20, 150],
    "busyTimeoutMs": 5000
  },
  "sidecar": {
    "maxConcurrentSessions": 20,
    "maxRetryCount": 3,
    "maxDelegateDepth": 2,
    "workerTimeoutSeconds": 300,
    "healthCheckTimeoutMs": 30000,
    "minSwarmSuccessRatio": 0.5,
    "teamslandApiBase": "http://localhost:3001"
  },
  "confirmation": {
    "reminderIntervalMin": 30,
    "maxReminders": 3,
    "pollIntervalMs": 60000
  },
  "dashboard": {
    "port": 3001,
    "auth": {
      "provider": "none",
      "sessionTtlHours": 8,
      "allowedDepartments": []
    }
  },
  "repoMapping": [
    {
      "meegoProjectId": "project_xxx",
      "repos": [{ "path": "~/teamsland-repos/teamsland", "name": "teamsland 主仓库" }]
    },
    {
      "meegoProjectId": "novel_admin",
      "repos": [
        {
          "path": "~/teamsland-repos/novel-admin-monorepo",
          "name": "novel-admin-monorepo",
          "remoteUrl": "git@code.byted.org:novel-fe/novel-admin-monorepo.git"
        }
      ]
    }
  ],
  "skillRouting": {
    "coding": ["lark-messaging", "teamsland-report"],
    "research": ["lark-messaging", "teamsland-report"],
    "review": ["lark-messaging", "teamsland-report"],
    "observer": ["teamsland-report"]
  },
  "llm": {
    "provider": "anthropic",
    "apiKey": "${ANTHROPIC_AUTH_TOKEN}",
    "model": "${ANTHROPIC_MODEL}",
    "baseUrl": "${ANTHROPIC_BASE_URL}",
    "maxTokens": 4096
  },
  "queue": {
    "dbPath": "data/queue.sqlite",
    "busyTimeoutMs": 5000,
    "visibilityTimeoutMs": 360000,
    "maxRetries": 3,
    "deadLetterEnabled": true,
    "pollIntervalMs": 100
  },
  "coordinator": {
    "workspacePath": "~/.teamsland/coordinator",
    "sessionIdleTimeoutMs": 7200000,
    "sessionMaxLifetimeMs": 7200000,
    "sessionReuseWindowMs": 300000,
    "maxRecoveryRetries": 3,
    "inferenceTimeoutMs": 300000,
    "enabled": true,
    "maxEventsPerSession": 20,
    "resultTimeoutMs": 300000
  },
  "hooks": {
    "hooksDir": "~/.teamsland/coordinator/hooks",
    "defaultTimeoutMs": 30000,
    "multiMatch": false,
    "pendingDir": "~/.teamsland/coordinator/hooks-pending",
    "requireApproval": true
  },
  "openViking": {
    "baseUrl": "http://127.0.0.1:1933",
    "agentId": "teamsland",
    "timeoutMs": 30000,
    "heartbeatIntervalMs": 30000,
    "heartbeatFailThreshold": 3
  }
}
