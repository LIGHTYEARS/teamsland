{
  "_comment": "结构化数据卡片 — 替换 {{TITLE}}、{{COLOR}}、{{COLUMNS}}、{{ROWS}}",
  "schema": "2.0",
  "config": {
    "wide_screen_mode": true
  },
  "header": {
    "title": {
      "tag": "plain_text",
      "content": "{{TITLE}}"
    },
    "template": "{{COLOR}}"
  },
  "body": {
    "elements": [
      {
        "tag": "table",
        "page_size": 10,
        "row_height": "low",
        "header_style": {
          "bold": true,
          "background_style": "grey"
        },
        "columns": "{{COLUMNS}}",
        "rows": "{{ROWS}}"
      }
    ]
  }
}
